# CONFIGURAÇÕES DA API
PORT=1350
NODE_ENV=development

# CONFIGURAÇÕES DO BANCO DE DADOS
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aplicativo_atividades_fisicas
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/aplicativo_atividades_fisicas_test

# CONFIGURAÇÕES DO POSTGRES
POSTGRES_DB=aplicativo_atividades_fisicas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BETTER_AUTH_SECRET=

BETTER_AUTH_URL=

# CONFIGURACOES DE UPLOAD (S3/GARAGEHQ)
MINIO_ENDPOINT=
MINIO_PORT=
MINIO_USE_SSL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_FOTOS=
# CDN público do bucket. Se vazio, as midias são servidas pelo proxy interno /api/media/*.
MINIO_PUBLIC_URL=
MINIO_LOCAL=false

# Base pública da API (proxy de midia) — ex: http://localhost:1350/api ou https://api.dominio.com/api
API_BASE_URL=http://localhost:1350/api

# ALIAS AWS (opcional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=
AWS_ENDPOINT_URL=
AWS_PUBLIC_URL=

# LIMITE MAXIMO (MB) PARA CADA ARQUIVO
UPLOAD_MAX_FILE_SIZE_MB=20

# API EXTERNA DE EXERCICIOS (ExerciseDB v2 — RapidAPI)
EXERCISEDB_API_KEY=
EXERCISEDB_API_HOST=exercisedb.p.rapidapi.com
EXERCISEDB_BASE_URL=https://exercisedb.p.rapidapi.com
